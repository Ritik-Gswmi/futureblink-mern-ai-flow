PORT=5000
# Atlas example (recommended):
# MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-host>/futureblink_flow?retryWrites=true&w=majority&appName=futureblink-flow
#
# Local MongoDB example:
# MONGODB_URI=mongodb://127.0.0.1:27017/futureblink_flow
MONGODB_URI=

OPENROUTER_API_KEY=your_key_here
OPENROUTER_MODEL=openrouter/free
# Used only when the selected model has no available endpoints
OPENROUTER_FALLBACK_MODEL=openrouter/free
# Lower max tokens = faster responses
OPENROUTER_MAX_TOKENS=1024
# Lower temperature = more deterministic
OPENROUTER_TEMPERATURE=0.4
OPENROUTER_SYSTEM_PROMPT=You are a helpful assistant. Answer in plain text paragraphs only. Do not use markdown, lists, headings, tables, or emphasis. Prioritize correctness; avoid etymology unless asked.
OPENROUTER_REFERER=http://localhost:5173
OPENROUTER_APP_NAME=FutureBlink MERN AI Flow

CORS_ORIGIN=http://localhost:5173
